generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JenisUdang {
  id         Int    @id @default(autoincrement())
  namaIlmiah String
  namaUmum   String
  habitat    String
  warna      String
  ukuranMin  Int
  ukuranMax  Int
  rostrum    String
  deskripsi  String
  gambarUrl  String?

  history History[]
}

model History {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  habitat   String
  warna     String?
  ukuranCm  Int
  rostrum   String
  hasilId   Int

  hasil JenisUdang @relation(fields: [hasilId], references: [id])
}
